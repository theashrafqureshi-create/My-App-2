<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1D"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How It Works"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This premium VPN is specially designed to secure and optimize your WhatsApp audio and video calls. Your calling data passes safely through our private servers, while your regular browsing and apps stay on your normal network to save speed."
            android:textColor="#8A94A6"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Why We Need Notification Access"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="We request notification permission solely to show a reliable connection status and a secure key icon in your status bar. This allows you to monitor or disconnect the service instantly at any time."
            android:textColor="#8A94A6"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_onboarding_allow"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#00E676"
        android:text="Grant &amp; Continue"
        android:textColor="#0A0F1D"
        android:textSize="18sp"
        android:textStyle="bold" />

</RelativeLayout>
