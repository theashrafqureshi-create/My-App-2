<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/manifest/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:padding="20dp">

    <!-- बैक बटन और टाइटल -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#075E54"
            android:textSize="18sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:layout_alignParentStart="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VPN Settings"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <!-- इनपुट बॉक्स -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shadowsocks Link (ss://)"
        android:textColor="#7F8C8D"
        android:textSize="14sp"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etVpnLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Paste ss:// link here..."
        android:inputType="textUri"
        android:background="@android:drawable/editbox_background_normal"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <!-- सेव बटन -->
    <Button
        android:id="@+id/btnSaveLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SAVE CONFIG"
        android:backgroundTint="#075E54"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Or Import Configuration"
        android:textColor="#7F8C8D"
        android:textSize="14sp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- कैमरा स्कैनर बटन -->
    <Button
        android:id="@+id/btnOpenScanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SCAN QR CODE (CAMERA)"
        android:backgroundTint="#0288D1"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <!-- गैलरी बटन -->
    <Button
        android:id="@+id/btnOpenGallery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="IMPORT FROM GALLERY"
        android:backgroundTint="#7B1FA2"
        android:textColor="#FFFFFF" />

</LinearLayout>
